{
  "name": "siliconflower",
  "version": "0.1.0",
  "description": "A CLI AI agent with MCP support, reasoning control, and OpenAI/Anthropic-compatible backends.",
  "type": "module",
  "bin": {
    "siliconflower": "bin/siliconflower.js"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun run src/index.tsx",
    "config": "bun run src/index.tsx config",
    "typecheck": "tsc --noEmit",
    "build": "bun run build.ts",
    "build:clean": "Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue; bun run build.ts",
    "install:bin": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install.ps1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@inquirer/prompts": "^7.2.1",
    "@modelcontextprotocol/sdk": "^1.9.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "figlet": "^1.8.0",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "openai": "^4.73.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/react": "^18.3.12",
    "bun-types": "^1.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
